SPRING_DATASOURCE_URL=jdbc:mysql://<host>:<port>/<database_name>?useSSL=true&requireSSL=true&verifyServerCertificate=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
PORT=8080
ALLOWED_ORIGINS=<comma_separated_origins_e.g._https://example.onrender.com,http://localhost:5173>
